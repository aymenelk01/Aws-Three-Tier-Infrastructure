{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Effect": "Allow",
        "Action": [
          "dynamodb:PutItem",
          "dynamodb:GetItem",
          "dynamodb:UpdateItem",
          "dynamodb:Query",
          "dynamodb:BatchWriteItem"
        ],
        "Resource": [
            "${dynamodb_session_table_arn}",
            "${dynamodb_user_table_arn}",
            "${dynamodb_user_table_arn}/index/EmailIndex"
        ]
      }
    ]
}